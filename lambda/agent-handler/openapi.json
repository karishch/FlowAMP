{
  "openapi": "3.0.0",
  "info": {
    "title": "Energy Agent Management API",
    "version": "2.0.0",
    "description": "Multi-platform API for managing AI agents across AWS Bedrock, Microsoft Copilot Studio, Okta Secure AI, and MuleSoft Agent Fabric. Includes compliance, operating policies, access controls, and cross-platform discovery."
  },
  "paths": {
    "/agents": {
      "get": {
        "operationId": "listAgents",
        "summary": "List all registered AI agents across all platforms",
        "description": "Returns all AI agents from native (AWS), Microsoft, Okta, and MuleSoft platforms. Optionally filter by platform.",
        "parameters": [
          {
            "name": "platform",
            "in": "query",
            "required": false,
            "description": "Filter by platform: native, microsoft, okta, mulesoft. Omit for all platforms.",
            "schema": { "type": "string", "description": "Platform filter" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of agents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "description": "Agent list",
                  "items": {
                    "type": "object",
                    "description": "Agent record",
                    "properties": {
                      "agentId": { "type": "string", "description": "Unique agent identifier" },
                      "name": { "type": "string", "description": "Agent name" },
                      "platform": { "type": "string", "description": "Source platform: native, microsoft, okta, mulesoft" },
                      "system": { "type": "string", "description": "Source system" },
                      "status": { "type": "string", "description": "Status" },
                      "category": { "type": "string", "description": "Category" },
                      "requests": { "type": "integer", "description": "Total requests" },
                      "errors": { "type": "integer", "description": "Total errors" },
                      "avgResponseMs": { "type": "number", "description": "Avg response ms" },
                      "monthlyCost": { "type": "number", "description": "Monthly cost USD" },
                      "costPerInvocation": { "type": "number", "description": "Cost per invocation USD" },
                      "utilization": { "type": "number", "description": "Utilization percent" },
                      "score": { "type": "number", "description": "RAI score" },
                      "fairness": { "type": "number", "description": "Fairness score" },
                      "transparency": { "type": "number", "description": "Transparency score" },
                      "accountability": { "type": "number", "description": "Accountability score" },
                      "ethics": { "type": "number", "description": "Ethics score" },
                      "owner": { "type": "string", "description": "Agent owner" },
                      "lastSyncedAt": { "type": "string", "description": "Last sync timestamp" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agents/{agentId}": {
      "get": {
        "operationId": "getAgent",
        "summary": "Get details of a specific agent",
        "description": "Returns full details for one agent by ID.",
        "parameters": [
          {
            "name": "agentId",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the agent",
            "schema": { "type": "string", "description": "Agent ID string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Agent details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Agent object",
                  "properties": {
                    "agentId": { "type": "string", "description": "ID" },
                    "name": { "type": "string", "description": "Name" },
                    "system": { "type": "string", "description": "System" },
                    "category": { "type": "string", "description": "Category" },
                    "status": { "type": "string", "description": "Status" },
                    "requests": { "type": "integer", "description": "Requests" },
                    "errors": { "type": "integer", "description": "Errors" },
                    "avgResponseMs": { "type": "number", "description": "Avg response ms" },
                    "monthlyCost": { "type": "number", "description": "Monthly cost" },
                    "score": { "type": "number", "description": "RAI score" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agents/{agentId}/metrics": {
      "get": {
        "operationId": "getAgentMetrics",
        "summary": "Get agent performance and cost metrics",
        "description": "Returns metrics including requests, errors, response time, cost, and utilization.",
        "parameters": [
          {
            "name": "agentId",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the agent",
            "schema": { "type": "string", "description": "Agent ID string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Agent metrics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Metrics object",
                  "properties": {
                    "agentId": { "type": "string", "description": "ID" },
                    "requests": { "type": "integer", "description": "Requests" },
                    "errors": { "type": "integer", "description": "Errors" },
                    "avgResponseMs": { "type": "number", "description": "Avg ms" },
                    "status": { "type": "string", "description": "Status" },
                    "monthlyCost": { "type": "number", "description": "Monthly cost" },
                    "costPerInvocation": { "type": "number", "description": "Cost per call" },
                    "utilization": { "type": "number", "description": "Utilization pct" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/compliance": {
      "get": {
        "operationId": "listCompliance",
        "summary": "List all compliance frameworks and scores",
        "description": "Returns compliance frameworks like NERC CIP, FERC, EPA, NIST AI RMF with scores, status, last audit date, and control details.",
        "responses": {
          "200": {
            "description": "Compliance frameworks list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "description": "Compliance frameworks",
                  "items": {
                    "type": "object",
                    "description": "Compliance framework record",
                    "properties": {
                      "name": { "type": "string", "description": "Framework name" },
                      "complianceScore": { "type": "number", "description": "Overall compliance score" },
                      "status": { "type": "string", "description": "compliant or warning" },
                      "lastAudit": { "type": "string", "description": "Last audit date" },
                      "controls": { "type": "string", "description": "JSON array of control names and scores" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/aops": {
      "get": {
        "operationId": "listAOPs",
        "summary": "List all Agent Operating Policies",
        "description": "Returns all AOPs with ID, name, status, assigned agents, execution count, success rate, owner, and trigger condition.",
        "responses": {
          "200": {
            "description": "AOP list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "description": "Agent Operating Policies",
                  "items": {
                    "type": "object",
                    "description": "AOP record",
                    "properties": {
                      "aopId": { "type": "string", "description": "AOP ID like AOP-E01" },
                      "name": { "type": "string", "description": "Policy name" },
                      "status": { "type": "string", "description": "active, draft, or review" },
                      "agents": { "type": "string", "description": "Comma-separated agent names" },
                      "executions": { "type": "integer", "description": "Total executions" },
                      "successRate": { "type": "number", "description": "Success rate percent" },
                      "owner": { "type": "string", "description": "Owning team" },
                      "entry": { "type": "string", "description": "Trigger condition" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/access": {
      "get": {
        "operationId": "listAccess",
        "summary": "List access control matrix",
        "description": "Returns user roles and their permissions across agent categories including Grid Ops, Asset Mgmt, Trading, Safety, and Customer.",
        "responses": {
          "200": {
            "description": "Access matrix entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "description": "Access control entries",
                  "items": {
                    "type": "object",
                    "description": "Access entry",
                    "properties": {
                      "userName": { "type": "string", "description": "User name" },
                      "role": { "type": "string", "description": "Job role" },
                      "accessLevel": { "type": "string", "description": "admin, engineer, or viewer" },
                      "gridOps": { "type": "string", "description": "Permission for Grid Ops category" },
                      "assetMgmt": { "type": "string", "description": "Permission for Asset Mgmt category" },
                      "trading": { "type": "string", "description": "Permission for Trading category" },
                      "safety": { "type": "string", "description": "Permission for Safety category" },
                      "customer": { "type": "string", "description": "Permission for Customer category" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/platforms": {
      "get": {
        "operationId": "listPlatforms",
        "summary": "List all connected agent platforms with summary stats",
        "description": "Returns each connected platform (native, microsoft, okta, mulesoft) with agent count, active count, total cost, and average RAI score.",
        "responses": {
          "200": {
            "description": "Platform summary list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "description": "Platform summaries",
                  "items": {
                    "type": "object",
                    "description": "Platform summary",
                    "properties": {
                      "platform": { "type": "string", "description": "Platform name" },
                      "agentCount": { "type": "integer", "description": "Total agents on this platform" },
                      "activeCount": { "type": "integer", "description": "Active agents" },
                      "totalMonthlyCost": { "type": "number", "description": "Combined monthly cost" },
                      "avgRaiScore": { "type": "number", "description": "Average RAI score across agents" },
                      "lastSyncedAt": { "type": "string", "description": "Last discovery sync timestamp" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agents/cross-platform-summary": {
      "get": {
        "operationId": "getCrossPlatformSummary",
        "summary": "Get aggregated metrics across all platforms",
        "description": "Returns total agent count, total cost, average RAI score, error rate, and per-platform breakdown. This is the single-pane-of-glass summary.",
        "responses": {
          "200": {
            "description": "Cross-platform summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Aggregated cross-platform metrics",
                  "properties": {
                    "totalAgents": { "type": "integer", "description": "Total agents across all platforms" },
                    "totalMonthlyCost": { "type": "number", "description": "Combined monthly cost" },
                    "avgRaiScore": { "type": "number", "description": "Average RAI score" },
                    "totalRequests": { "type": "integer", "description": "Total requests across all agents" },
                    "totalErrors": { "type": "integer", "description": "Total errors across all agents" },
                    "platformBreakdown": { "type": "string", "description": "JSON object with per-platform counts and costs" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
